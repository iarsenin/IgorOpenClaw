# ============================================================
# IgorOpenClaw — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
#   cp .env.example .env
#   chmod 600 .env
# NEVER commit .env to git.
# ============================================================

# --- LLM Providers ---
OPENAI_API_KEY=sk-your-openai-api-key
# Admin key (org-level, read-only: Usage+Billing) — used by api-spend-check cron
# Create at: platform.openai.com/settings/organization/api-keys
# Restrict scopes to: Usage=Read, Billing=Read (do NOT grant Write/Manage)
OPENAI_ADMIN_KEY=sk-admin-your-openai-admin-key
GOOGLE_API_KEY=AIza-your-google-api-key
GEMINI_API_KEY=AIza-your-google-api-key

# --- Hugging Face ---
HUGGING_FACE_TOKEN=hf_your-hugging-face-token

# --- OpenClaw Gateway ---
OPENCLAW_AUTH_TOKEN=generate-a-256-bit-random-token-here

# --- Email (Gmail IMAP/SMTP) ---
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# --- Email (Yahoo IMAP/SMTP) ---
YAHOO_USER=your_email@yahoo.com
YAHOO_APP_PASSWORD=your-yahoo-app-password

# --- Alpha Vantage (financial data) ---
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# --- Vapi (AI phone calls) ---
VAPI_API_KEY=your-vapi-private-api-key
VAPI_ASSISTANT_ID=your-vapi-assistant-id
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id
VAPI_PHONE_NUMBER=+1234567890

# --- gog (Google Workspace CLI) ---
# File-based keyring password so the daemon can access Google OAuth tokens
# without triggering macOS Keychain popups. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(24))"
# After setting, run: gog auth keyring file && GOG_KEYRING_PASSWORD=<pw> gog auth tokens import <exported-token>
GOG_KEYRING_PASSWORD=your-random-keyring-password

# --- Timezone ---
TZ=America/New_York
