{
  // OpenClaw Configuration — IgorOpenClaw
  // After editing, restart the gateway: openclaw gateway restart
  // Token is injected from .env by setup.sh — DO NOT hardcode secrets here.

  meta: {
    lastTouchedVersion: "2026.3.28",
    lastTouchedAt: "2026-04-01T15:00:00Z",
  },

  agents: {
    defaults: {
      model: {
        primary: "openai/gpt-5.4-mini",
        fallbacks: ["google/gemini-2.5-pro"],
      },
      workspace: "~/.openclaw/workspace",
    },
    list: [
      {
        id: "main",
        identity: {
          name: "Clawd",
          theme: "personal autonomous assistant",
        },
      },
    ],
  },

  tools: {
    elevated: {
      enabled: true,
    },
    exec: {
      // host: "gateway" makes all exec default to gateway host.
      // Cron/isolated sessions have no approval UI, so exec-approvals.json
      // must have askFallback: "full" — this auto-approves exec when no
      // UI is available. The agent may first attempt host=sandbox (fails),
      // then retry with gateway (succeeds via askFallback). Those first-
      // attempt errors in the log are cosmetic; exec works correctly.
      host: "gateway",
      pathPrepend: [
        "/Library/Frameworks/Python.framework/Versions/3.10/bin",
        "/opt/homebrew/bin",
      ],
    },
  },

  commands: {
    native: "auto",
    nativeSkills: "auto",
    restart: true,
    ownerDisplay: "raw",
  },

  channels: {
    whatsapp: {
      enabled: true,
      dmPolicy: "allowlist",
      allowFrom: ["+19179752041", "+19176997436"],
      groupPolicy: "disabled",
      groups: {},
      debounceMs: 0,
      accounts: {
        default: {
          enabled: true,
          dmPolicy: "allowlist",
          groupPolicy: "disabled",
          debounceMs: 0,
        },
      },
      mediaMaxMb: 50,
    },
  },

  gateway: {
    port: 18789,
    mode: "local",
    auth: {
      mode: "token",
      token: "__OPENCLAW_AUTH_TOKEN__",
    },
  },
}
