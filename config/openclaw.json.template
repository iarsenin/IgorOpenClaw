  commands: {
    native: "auto",
    nativeSkills: "auto",
    restart: true,
    ownerDisplay: "raw",
  },

  channels: {
    whatsapp: {
      enabled: true,
      dmPolicy: "allowlist",
      allowFrom: ["+19179752041"],
      groupPolicy: "disabled",
      groups: {},
      debounceMs: 0,
      accounts: {
        default: {
          enabled: true,
          dmPolicy: "allowlist",
          groupPolicy: "disabled",
          debounceMs: 0,
        },
      },
      mediaMaxMb: 50,
    },
  },

  gateway: {
    port: 18789,
    mode: "local",
    auth: {
      mode: "token",
      token: "__OPENCLAW_AUTH_TOKEN__",
    },
  },
